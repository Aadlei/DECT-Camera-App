@using System.Text
@using DECT_Shared.Models
@using DECT_Web.Services
@using Radzen.Blazor.Markdown
@implements IDisposable

@inject MongoDbServices MongoDbService

<RadzenCard class="p-3">
    @if (Image is not null)
    {
        <RadzenCard Variant="Variant.Outlined"
                    Style="display: inline-block; width: fit-content; max-width: 100%; border-radius: 12px;">
            <RadzenStack Gap="0.75rem" Style="padding: 1rem;">

                @* ── Header ── *@
                <RadzenStack Orientation="Orientation.Horizontal"
                             AlignItems="AlignItems.Center"
                             JustifyContent="JustifyContent.SpaceBetween"
                             Gap="0.75rem">
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="fw-semibold">
                        Transmitter
                    </RadzenText>
                    <RadzenBadge Text="@TransmitterId.ToString()" BadgeStyle="BadgeStyle.Primary"/>
                </RadzenStack>

                @* ── Image ── *@
                <div style="--imgw: 640px; width: min(100%, var(--imgw));">
                    <RadzenImage Path="@Image.ImageDataUrl"
                                 Style="width: 100%; height: auto; display: block; border-radius: 10px;"/>
                </div>

                @if (Images.Count > 1)
                {
                    <RadzenSlider Style="width:100%" TValue="int"
                                  Min="0" Max="@(Images.Count - 1)" @bind-Value="_imageIndex"/>
                }

                @* ── Timestamp ── *@
                <RadzenStack Orientation="Orientation.Horizontal"
                             AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="schedule" class="text-muted"/>
                    <RadzenText TextStyle="TextStyle.Body2" class="text-muted">
                        Last image:
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" class="fw-semibold"
                                Style="word-break: break-word;">
                        @Image.DeviceTimestamp.ToLocalTime()
                    </RadzenText>
                </RadzenStack>
            </RadzenStack>

            @* ── Metrics Panel ── *@
            @if (Session is not null)
            {
                <RadzenPanel AllowCollapse Collapsed="false" class="rz-my-5">
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6"
                                    class="rz-display-flex rz-align-items-center">
                            <RadzenIcon Icon="speed" class="rz-me-1"/>
                            <b>Experiment Metrics</b>
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenStack Gap="0.5rem" Style="padding: 0.75rem;">
                            <RadzenRow Gap="0.75rem" RowGap="0.75rem">
                                <RadzenColumn Size="6">
                                    <MetricTile Label="Images" Value="@Session.TotalImages.ToString()"/>
                                </RadzenColumn>
                                <RadzenColumn Size="6">
                                    <MetricTile Label="Total Data" Value="@FormatBytes(Session.TotalBytes)"/>
                                </RadzenColumn>
                                <RadzenColumn Size="6">
                                    <MetricTile Label="Throughput"
                                                Value="@($"{Session.ThroughputBytesPerSecond * 8 / 1000:F0} kbps")"/>
                                </RadzenColumn>
                                <RadzenColumn Size="6">
                                    <MetricTile Label="Avg Inter-Arrival"
                                                Value="@($"{Session.AvgInterArrivalMs:F0} ms")"/>
                                </RadzenColumn>
                                <RadzenColumn Size="6">
                                    <MetricTile Label="Avg Hops" Value="@($"{Session.AvgHopCount:F1}")"/>
                                </RadzenColumn>
                                <RadzenColumn Size="6">
                                    <MetricTile Label="Avg E2E Latency"
                                                Value="@($"{Session.AvgEndToEndDelayMs:F0} ms")"/>
                                </RadzenColumn>
                                <RadzenColumn Size="6">
                                    <MetricTile Label="Packet Loss"
                                                Value="@($"{Session.PacketLossPercent:F1} %")"/>
                                </RadzenColumn>
                                <RadzenColumn Size="6">
                                    <MetricTile Label="Avg RSSI"
                                                Value="@($"{Session.AvgRssiDbm:F1} dBm")"/>
                                </RadzenColumn>
                            </RadzenRow>
                        </RadzenStack>
                    </ChildContent>
                </RadzenPanel>
            }

            @* ── Inter-Arrival Time ── *@
            <RadzenPanel Collapsed="false" AllowCollapse class="rz-my-10">
                <HeaderTemplate>
                    <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                        <RadzenIcon Icon="grouped_bar_chart" class="rz-me-1"/>
                        <b>Inter-Arrival Time</b>
                    </RadzenText>
                </HeaderTemplate>
                <ChildContent>
                    @if (_interArrivalData.Count > 1)
                    {
                        <div id="@($"interarrival-chart-{TransmitterId}")">
                            <RadzenChart Style="height: 250px;">
                                <RadzenLineSeries Data="_interArrivalData"
                                                  CategoryProperty="Seq"
                                                  ValueProperty="Ms"
                                                  Title="Inter-arrival"
                                                  Smooth="true">
                                    <RadzenMarkers MarkerType="MarkerType.Circle" Size="4"/>
                                </RadzenLineSeries>
                                <RadzenCategoryAxis>
                                    <RadzenAxisTitle Text="image #"/>
                                </RadzenCategoryAxis>
                                <RadzenValueAxis FormatString="{0:F0}">
                                    <RadzenAxisTitle Text="ms"/>
                                </RadzenValueAxis>
                                <RadzenChartTooltipOptions Shared="false"/>
                            </RadzenChart>
                        </div>
                    }
                    else
                    {
                        <RadzenText TextStyle="TextStyle.Body2" class="text-muted" Style="padding: 1rem;">
                            Waiting for data...
                        </RadzenText>
                    }
                </ChildContent>
            </RadzenPanel>

            @* ── Topology ── *@
            @if (Image?.DevicesVisited?.Count > 1)
            {
                <RadzenPanel AllowCollapse Collapsed="false" class="rz-my-10">
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="device_hub" class="rz-me-1"/>
                            <b>Last Path</b>
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <div style="overflow-x: auto; padding: 1rem;">
                            @((MarkupString)BuildTopologySvg())
                        </div>
                    </ChildContent>
                </RadzenPanel>
            }

            @* ── Throughput ── *@
            <RadzenPanel Collapsed="false" AllowCollapse class="rz-my-10">
                <HeaderTemplate>
                    <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                        <RadzenIcon Icon="speed" class="rz-me-1"/>
                        <b>Throughput</b>
                    </RadzenText>
                </HeaderTemplate>
                <ChildContent>
                    @if (_throughputData.Count > 1)
                    {
                        <div id="@($"throughput-chart-{TransmitterId}")">
                            <RadzenChart Style="height: 280px;">
                                <RadzenAreaSeries Data="_throughputData"
                                                  CategoryProperty="ElapsedSeconds"
                                                  ValueProperty="Kbps"
                                                  Title="kbps"
                                                  Smooth="true">
                                    <RadzenMarkers MarkerType="MarkerType.None"/>
                                </RadzenAreaSeries>
                                <RadzenCategoryAxis FormatString="{0:F0}">
                                    <RadzenAxisTitle Text="Elapsed (s)"/>
                                </RadzenCategoryAxis>
                                <RadzenValueAxis FormatString="{0:F0}">
                                    <RadzenAxisTitle Text="kbps"/>
                                </RadzenValueAxis>
                                <RadzenChartTooltipOptions Shared="false"/>
                            </RadzenChart>
                        </div>
                    }
                    else
                    {
                        <RadzenText TextStyle="TextStyle.Body2" class="text-muted" Style="padding: 1rem;">
                            Waiting for data...
                        </RadzenText>
                    }
                </ChildContent>
            </RadzenPanel>

            @* ── Per-Link Delay ── *@
            @if (_perLinkData.Count > 0)
            {
                <RadzenPanel Collapsed="false" AllowCollapse class="rz-my-10">
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="timeline" class="rz-me-1"/>
                            <b>Per-Link Delay</b>
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <div id="@($"linkdelay-chart-{TransmitterId}")">
                            <RadzenChart Style="height: 280px;">
                                @foreach (var (linkIdx, points) in _perLinkData.OrderBy(kv => kv.Key))
                                {
                                    <RadzenLineSeries Data="points"
                                                      CategoryProperty="Seq"
                                                      ValueProperty="Ms"
                                                      Title="@GetLinkLabel(linkIdx)"
                                                      Smooth="true">
                                        <RadzenMarkers MarkerType="MarkerType.None"/>
                                    </RadzenLineSeries>
                                }
                                <RadzenCategoryAxis>
                                    <RadzenAxisTitle Text="image #"/>
                                </RadzenCategoryAxis>
                                <RadzenValueAxis FormatString="{0:F0}">
                                    <RadzenAxisTitle Text="ms"/>
                                </RadzenValueAxis>
                                <RadzenLegend Position="LegendPosition.Bottom"/>
                                <RadzenChartTooltipOptions Shared="true"/>
                            </RadzenChart>
                        </div>
                    </ChildContent>
                </RadzenPanel>
            }

            @* ── Per-Link RSSI ── *@
            @if (_perLinkRssiData.Count > 0)
            {
                <RadzenPanel Collapsed="false" AllowCollapse class="rz-my-10">
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="signal_cellular_alt" class="rz-me-1"/>
                            <b>Per-Link RSSI</b>
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <div id="@($"rssi-chart-{TransmitterId}")">
                            <RadzenChart Style="height: 280px;">
                                @foreach (var (linkIdx, points) in _perLinkRssiData.OrderBy(kv => kv.Key))
                                {
                                    <RadzenLineSeries Data="points"
                                                      CategoryProperty="Seq"
                                                      ValueProperty="Dbm"
                                                      Title="@GetLinkLabel(linkIdx)"
                                                      Smooth="true">
                                        <RadzenMarkers MarkerType="MarkerType.None"/>
                                    </RadzenLineSeries>
                                }
                                <RadzenCategoryAxis>
                                    <RadzenAxisTitle Text="image #"/>
                                </RadzenCategoryAxis>
                                <RadzenValueAxis FormatString="{0:F0}">
                                    <RadzenAxisTitle Text="dBm"/>
                                </RadzenValueAxis>
                                <RadzenLegend Position="LegendPosition.Bottom"/>
                                <RadzenChartTooltipOptions Shared="true"/>
                            </RadzenChart>
                        </div>
                    </ChildContent>
                </RadzenPanel>
            }

        </RadzenCard>
    }
</RadzenCard>


@code {
    [Parameter] public string TransmitterId { get; set; }
    [Parameter] public bool ExperimentRunning { get; set; }

    /// <summary>UTC timestamp when the experiment was started. Null = no experiment.</summary>
    [Parameter] public DateTime? ExperimentStartUtc { get; set; }

    /// <summary>Expose session so parent can aggregate for CSV export.</summary>
    [Parameter] public EventCallback<ExperimentDto?> SessionChanged { get; set; }

    public ExperimentDto?  Session { get; private set; }
    public List<ImageDto>  Images  { get; set; } = new();
    private ImageDto? Image => Images?.Count > 0 ? Images[Images.Count - 1 - _imageIndex] : null;

    private DateTime? _lastImageTimestamp;
    private CancellationTokenSource? _pollCts;
    private readonly HashSet<string> _seenImageKeys = new();
    private int  _imageIndex;
    private int  _sequenceCounter;
    private bool _wasRunning;

    /* Radzen re-renders the entire chart on every StateHasChanged, so cap the
     * number of points to keep render time bounded during long experiments. */
    private const int MaxChartPoints = 400;

    // ── Graph data ────────────────────────────────────────────────────────
    private record InterArrivalPoint(int Seq, double Ms);
    private readonly List<InterArrivalPoint> _interArrivalData = new();

    private record ThroughputPoint(double ElapsedSeconds, double Kbps);
    private readonly List<ThroughputPoint> _throughputData = new();

    private record LinkDelayPoint(int Seq, double Ms);
    private readonly Dictionary<int, List<LinkDelayPoint>> _perLinkData = new();

    private record E2EPoint(int Seq, double Ms);
    private readonly List<E2EPoint> _e2eData = new();

    private record RssiPoint(int Seq, double Dbm);
    private readonly Dictionary<int, List<RssiPoint>> _perLinkRssiData = new();

    // ── Packet loss tracking ──────────────────────────────────────────────
    private int _lastSeenSeqNum = -1;
    private int _totalExpected  = 0;

    // ─────────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadImages();
        StartPolling();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ExperimentRunning && !_wasRunning)
        {
            Reset();
            StartPolling();
            await NotifySessionChanged();
        }

        if (!ExperimentRunning && _wasRunning && Session is not null)
        {
            _pollCts?.Cancel();
            Session.EndTime = DateTime.UtcNow;
            await NotifySessionChanged();
        }

        _wasRunning = ExperimentRunning;
    }

    private void StartPolling()
    {
        _pollCts?.Cancel();
        _pollCts = new CancellationTokenSource();
        _ = PollLoop(_pollCts.Token);
    }

    private async Task PollLoop(CancellationToken ct)
    {
        /* PeriodicTimer never overlaps — it waits for the handler to finish
         * before scheduling the next tick. This prevents the burst of queued
         * callbacks that System.Threading.Timer fires when a background tab
         * becomes active again, which was causing the chart glitching. */
        using var pt = new PeriodicTimer(TimeSpan.FromMilliseconds(500));
        try
        {
            while (await pt.WaitForNextTickAsync(ct))
            {
                var prevCount = Images.Count;
                await LoadImages();
                bool changed = Images.Count != prevCount;

                if (ExperimentRunning && Session is not null)
                {
                    CollectMetrics();
                    changed = true; // always re-render during experiment
                }

                if (changed)
                    await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadImages()
    {
        var fetched = await MongoDbService.GetLastXImagesAsync(TransmitterId, 20);

        Images = ExperimentStartUtc.HasValue && Session is not null
            ? fetched.Where(img => img.DeviceTimestamp >= Session.StartTime).ToList()
            : fetched;

        if (_imageIndex >= Images.Count)
            _imageIndex = Math.Max(0, Images.Count - 1);
    }

    private void CollectMetrics()
    {
        if (Session is null) return;

        foreach (var img in Images)
        {
            if (img.DeviceTimestamp < Session.StartTime) continue;

            var key = $"{img.TransmitterId}_{img.DeviceTimestamp.Ticks}_{img.SizeBytes}";
            if (!_seenImageKeys.Add(key)) continue;

            // ── Inter-arrival ─────────────────────────────────────────────
            if (_lastImageTimestamp.HasValue)
            {
                var ms = (img.DeviceTimestamp - _lastImageTimestamp.Value).TotalMilliseconds;
                AddCapped(_interArrivalData, new InterArrivalPoint(_sequenceCounter, ms));
            }
            _lastImageTimestamp = img.DeviceTimestamp;

            // ── Session entry ─────────────────────────────────────────────
            Session.Entries.Add(new ImageDto
            {
                TransmitterId   = img.TransmitterId,
                DeviceTimestamp = img.DeviceTimestamp,
                ReceivedAt      = DateTime.UtcNow,
                SizeBytes       = img.SizeBytes,
                HopCount        = img.HopCount,
                SequenceNumber  = _sequenceCounter++,
                PerLinkDelayMs  = img.PerLinkDelayMs,
                PerLinkRssi     = img.PerLinkRssi,
            });

            // ── Throughput ────────────────────────────────────────────────
            var elapsed = (DateTime.UtcNow - Session.StartTime).TotalSeconds;
            if (elapsed > 0)
            {
                var kbps = Session.TotalBytes * 8.0 / 1000 / elapsed;
                AddCapped(_throughputData, new ThroughputPoint(Math.Round(elapsed, 1), Math.Round(kbps, 0)));
            }

            // ── Per-link delay ────────────────────────────────────────────
            if (img.PerLinkDelayMs?.Count > 1)
            {
                for (int li = 1; li < img.PerLinkDelayMs.Count; li++)
                {
                    if (!_perLinkData.ContainsKey(li))
                        _perLinkData[li] = new();
                    AddCapped(_perLinkData[li], new LinkDelayPoint(_sequenceCounter, img.PerLinkDelayMs[li]));
                }
                AddCapped(_e2eData, new E2EPoint(_sequenceCounter, img.EndToEndDelayMs));
            }

            // ── Per-link RSSI ─────────────────────────────────────────────
            if (img.PerLinkRssi?.Count > 0)
            {
                for (int li = 0; li < img.PerLinkRssi.Count; li++)
                {
                    if (img.PerLinkRssi[li] == 0) continue;
                    if (!_perLinkRssiData.ContainsKey(li))
                        _perLinkRssiData[li] = new();
                    AddCapped(_perLinkRssiData[li], new RssiPoint(_sequenceCounter, img.PerLinkRssi[li]));
                }
            }

            // ── Packet loss ───────────────────────────────────────────────
            if (img.SequenceNumber > 0)
            {
                if (_lastSeenSeqNum >= 0)
                {
                    int gap = img.SequenceNumber - _lastSeenSeqNum - 1;
                    if (gap > 0)
                    {
                        Session.DroppedPackets += gap;
                        _totalExpected += gap;
                    }
                }
                _lastSeenSeqNum = img.SequenceNumber;
                _totalExpected++;
            }
        }
    }

    private async Task NotifySessionChanged()
    {
        if (SessionChanged.HasDelegate)
            await SessionChanged.InvokeAsync(Session);
    }

    private void Reset()
    {
        Images.Clear();
        _imageIndex = 0;
        Session = new ExperimentDto { StartTime = ExperimentStartUtc ?? DateTime.UtcNow };
        _seenImageKeys.Clear();
        _sequenceCounter = 0;
        _interArrivalData.Clear();
        _lastImageTimestamp = null;
        _throughputData.Clear();
        _perLinkData.Clear();
        _e2eData.Clear();
        _perLinkRssiData.Clear();
        _lastSeenSeqNum = -1;
        _totalExpected  = 0;
    }

    private static string FormatBytes(long bytes) => bytes switch
    {
        >= 1_048_576 => $"{bytes / 1_048_576.0:F1} MB",
        >= 1024      => $"{bytes / 1024.0:F1} KB",
        _            => $"{bytes} B"
    };

    private static string GetDeviceLabel(int index, int total) => (index, total) switch
    {
        (0, _)                    => "Edge PT",
        _ when index == total - 1 => "Sink FT",
        _                         => $"Relay {index}",
    };

    private string GetLinkLabel(int linkIdx)
    {
        // linkIdx 0 = Edge PT→first relay/sink, 1 = relay→sink, etc.
        var nodes = Image?.DevicesVisited;
        if (nodes is null || nodes.Count < 2) return $"Link {linkIdx}";
        var from = GetDeviceLabel(linkIdx,     nodes.Count);
        var to   = GetDeviceLabel(linkIdx + 1, nodes.Count);
        return $"{from} → {to}";
    }

    private string BuildTopologySvg()
    {
        if (Image?.DevicesVisited == null || Image.DevicesVisited.Count < 2)
            return string.Empty;

        var nodes = Image.DevicesVisited;
        var delays = Image.PerLinkDelayMs;
        var rssi   = Image.PerLinkRssi;
        int total  = nodes.Count;
        int nodeW  = 110, nodeH = 44, gap = 90;
        int svgH   = 120; // taller to fit delay + rssi labels
        int svgW   = total * nodeW + (total - 1) * gap + 20;
        int nodeY  = (svgH - nodeH) / 2; // vertically centred
        int arrowY = nodeY + nodeH / 2;

        var sb = new StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {svgW} {svgH}\" style=\"width:100%; min-width:{svgW}px; height:{svgH}px;\" xmlns=\"http://www.w3.org/2000/svg\">");
        sb.Append($"<defs><marker id=\"arr-{TransmitterId}\" markerWidth=\"8\" markerHeight=\"8\" refX=\"6\" refY=\"3\" orient=\"auto\">");
        sb.Append("<path d=\"M0,0 L0,6 L8,3 z\" fill=\"#888\"/></marker></defs>");

        for (int i = 0; i < total; i++)
        {
            int x  = 10 + i * (nodeW + gap);
            int cx = x + nodeW / 2;
            string label = GetDeviceLabel(i, total);

            sb.Append($"<rect x=\"{x}\" y=\"{nodeY}\" width=\"{nodeW}\" height=\"{nodeH}\" rx=\"8\" fill=\"#3d8bff\" fill-opacity=\"0.85\"/>");
            sb.Append($"<text x=\"{cx}\" y=\"{nodeY + 19}\" text-anchor=\"middle\" fill=\"white\" font-size=\"11\" font-weight=\"bold\">{label}</text>");
            sb.Append($"<text x=\"{cx}\" y=\"{nodeY + 33}\" text-anchor=\"middle\" fill=\"white\" font-size=\"9\" opacity=\"0.75\">{nodes[i]}</text>");

            if (i < total - 1)
            {
                int arrowX0 = x + nodeW;
                int arrowX1 = x + nodeW + gap;
                int midX    = (arrowX0 + arrowX1) / 2;

                // Delay above arrow
                string delayLabel = (i + 1 < delays.Count && delays[i + 1] > 0)
                    ? $"{delays[i + 1]} ms" : "—";
                // RSSI below arrow
                string rssiLabel = (rssi is not null && i + 1 < rssi.Count && rssi[i + 1] != 0)
                    ? $"{rssi[i + 1]} dBm" : "—";

                sb.Append($"<line x1=\"{arrowX0}\" y1=\"{arrowY}\" x2=\"{arrowX1 - 4}\" y2=\"{arrowY}\" stroke=\"#888\" stroke-width=\"2\" marker-end=\"url(#arr-{TransmitterId})\"/>");
                sb.Append($"<text x=\"{midX}\" y=\"{arrowY - 8}\" text-anchor=\"middle\" fill=\"#555\" font-size=\"10\">{delayLabel}</text>");
                sb.Append($"<text x=\"{midX}\" y=\"{arrowY + 18}\" text-anchor=\"middle\" fill=\"#c0392b\" font-size=\"10\">{rssiLabel}</text>");
            }
        }

        sb.Append("</svg>");
        return sb.ToString();
    }

    /* Removes the oldest point when the list is full, keeping chart render
     * cost bounded regardless of experiment duration. */
    private static void AddCapped<T>(List<T> list, T item)
    {
        if (list.Count >= MaxChartPoints)
            list.RemoveAt(0);
        list.Add(item);
    }

    public void Dispose()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
    }
}
