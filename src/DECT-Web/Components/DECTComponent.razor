@using Camera_DECT.Models
@using DECT_Web.Services
@implements IDisposable

@inject MongoDbServices MongoDbService

<RadzenCard class="p-3">
    @if (Image is not null)
    {
        <RadzenCard Variant="Variant.Outlined"
                    Style="
                        display: inline-block;
                        width: fit-content;
                        max-width: 100%;
                        border-radius: 12px;
                    ">
            <RadzenStack Gap="0.75rem" Style="padding: 1rem;">
                <RadzenStack Orientation="Orientation.Horizontal"
                             AlignItems="AlignItems.Center"
                             JustifyContent="JustifyContent.SpaceBetween"
                             Gap="0.75rem"
                             Style="max-width: 100%;">
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="fw-semibold">
                        Transmitter
                    </RadzenText>

                    <RadzenBadge Text="@Image.TransmitterId.ToString()" BadgeStyle="BadgeStyle.Primary" />
                </RadzenStack>
                
                <div style="--imgw: 640px; width: min(100%, var(--imgw));">
                    <RadzenImage Path="@Image.ImageDataUrl"
                                 Style="width: 100%; height: auto; display: block; border-radius: 10px;" />
                </div>
                
                <RadzenSlider Style="width:100%" TValue="int" Min="0" Max="@(Images.Count - 1)" @bind-Value="_imageIndex" />

                <RadzenStack Orientation="Orientation.Horizontal"
                             AlignItems="AlignItems.Center"
                             Gap="0.5rem"
                             Style="max-width: 100%;">
                    <RadzenIcon Icon="schedule" class="text-muted" />
                    <RadzenText TextStyle="TextStyle.Body2" class="text-muted">
                        Last image:
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" class="fw-semibold" Style="word-break: break-word;">
                        @Image.Timestamp.ToLocalTime()
                    </RadzenText>
                </RadzenStack>
                
                
            </RadzenStack>
            <RadzenPanel Collapsed="true" AllowCollapse  class="rz-my-5">
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center">
                            <RadzenIcon Icon="assessment" class="rz-me-1" /><b>@Images.Count Metrics</b>
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenTable>
                            <RadzenTableHeader>
                                <RadzenTableHeaderRow>
                                    <RadzenTableHeaderCell>
                                        Test
                                    </RadzenTableHeaderCell>
                                    <RadzenTableHeaderCell>
                                        Bytes
                                    </RadzenTableHeaderCell>
                                    <RadzenTableHeaderCell>
                                        Hops
                                    </RadzenTableHeaderCell>
                                </RadzenTableHeaderRow>
                            </RadzenTableHeader>
                            <RadzenTableBody>
                                @foreach (var image in Images)
                                {
                                    <RadzenTableRow>
                                        <RadzenTableCell>@image.Timestamp</RadzenTableCell>
                                        <RadzenTableCell>@image.SizeBytes</RadzenTableCell>
                                        <RadzenTableCell>@image.HopCount</RadzenTableCell>
                                    </RadzenTableRow>
                                }
                            </RadzenTableBody>
                        </RadzenTable>
                    </ChildContent>

                </RadzenPanel>
                <RadzenPanel Collapsed="true" AllowCollapse class="rz-my-10">
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="grouped_bar_chart" class="rz-me-1" /><b>Graphs</b>
                        </RadzenText>
                    </HeaderTemplate>
                </RadzenPanel>
        </RadzenCard>
    }
</RadzenCard>
@code {
    [Parameter] public int TransmitterId { get; set; }
    private int _imageIndex = 0;
    public List<ImageDto> Images { get; set; }
    private ImageDto? Image => Images?.Count > 0 ? Images[Images.Count - 1 - _imageIndex] : null;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadImage();
        _timer = new Timer(async void (_) =>
        {
            //await LoadImage();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(0), TimeSpan.FromSeconds(0.1));
    }

    private async Task LoadImage()
    {
        Images = await MongoDbService.GetLastXImagesAsync(TransmitterId, 20);
        _imageIndex = Images.Count-1;
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}