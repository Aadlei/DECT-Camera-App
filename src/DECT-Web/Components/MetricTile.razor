@* MetricTile.razor — Small stat card for the experiment dashboard *@

<RadzenCard Variant="Variant.Outlined" Style="text-align: center; padding: 0.75rem;">
    <RadzenText TextStyle="TextStyle.Overline" class="text-muted" Style="margin-bottom: 0.25rem;">
        @Label
    </RadzenText>
    <RadzenText TextStyle="TextStyle.H5" class="fw-semibold" Style="font-variant-numeric: tabular-nums;">
        @Value
    </RadzenText>
</RadzenCard>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "–";
}